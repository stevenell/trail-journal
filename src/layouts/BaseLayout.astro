---
import "../styles/global.css";
import photosData from "../data/photos.json";
import bgListData from "../data/backgrounds.json";

interface Props {
  title?: string;
  active?: "home" | "trail" | "photos";
  fullBleed?: boolean;
  description?: string;
  /** Site-relative path (e.g. "/photos/foo.jpg") — gets resolved against Astro.site for absolute OG URLs. */
  image?: string;
  /** og:type — "website" for index/photos/trail, "article" for individual day posts. */
  ogType?: "website" | "article";
}

// Background candidates. `build_data.py` writes src/data/backgrounds.json
// each time it syncs <PCT>\backgrounds\ -> public/bg/, so this list is
// committed to git and works in any build environment (no node:fs needed,
// which matters for Cloudflare's prerender Worker).
const bgCandidates: string[] = (bgListData as string[]).filter((f) =>
  /\.(jpe?g|png|webp)$/i.test(f)
);

// Default OG image: the first photo on file, sorted chronologically.
// Stable across builds (doesn't shift when new photos arrive).
const defaultPhoto = (photosData as any[])
  .filter((p) => p.file)
  .sort((a, b) => (a.taken_at || "").localeCompare(b.taken_at || ""))[0];
const DEFAULT_OG_IMAGE = defaultPhoto ? `/photos/${defaultPhoto.file}` : "/favicon.svg";

const SITE_NAME = "Emily's PCT 2026";

const {
  title = SITE_NAME,
  active = "home",
  fullBleed = false,
  description = "Daily journal, photos, and trail map from Emily's 2026 Pacific Crest Trail thru-hike.",
  image = DEFAULT_OG_IMAGE,
  ogType = "website",
} = Astro.props;

// Resolve absolute URLs (OG/Twitter expects them).
const siteOrigin = Astro.site ?? new URL("/", Astro.url);
const ogImage = new URL(image, siteOrigin).toString();
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#06091a" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={`Photo from ${SITE_NAME}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://tile.openstreetmap.org" />

    {bgCandidates.length > 0 && (
      <script is:inline define:vars={{ bgCandidates }}>
        // Pick a random background and apply it before paint. Persists the
        // pick in sessionStorage so navigating between pages doesn't reshuffle —
        // refresh or click "next bg" to cycle.
        (function () {
          if (!Array.isArray(bgCandidates) || bgCandidates.length === 0) return;
          const KEY = "pct_bg_choice";
          let chosen = sessionStorage.getItem(KEY);
          if (!chosen || !bgCandidates.includes(chosen)) {
            chosen = bgCandidates[Math.floor(Math.random() * bgCandidates.length)];
            sessionStorage.setItem(KEY, chosen);
          }
          // Layer order matches global.css (#1 image, #2-11 stars, #12-13 gradients).
          // Setting backgroundImage on body via inline style overrides the rule.
          document.documentElement.style.setProperty("--bg-image", `url("/bg/${chosen}")`);
          window.__pctBg = { all: bgCandidates, current: chosen };
        })();
      </script>
    )}
  </head>
  <body>
    <div class={fullBleed ? "app app--full" : "app"}>
      {!fullBleed && (
        <header class="site-header">
          <div class="site-header__row">
            <h1 class="site-header__title">
              <a href="/">Emily's PCT 2026</a>
            </h1>
          </div>
        </header>
      )}

      <main>
        <slot />
      </main>

      {bgCandidates.length > 1 && (
        <div class="bg-picker" id="bg-picker" aria-label="Background picker" hidden>
          <span class="bg-picker__name" id="bg-picker-name"></span>
          <button type="button" class="bg-picker__btn" id="bg-picker-next" title="Try another background">
            next bg <span aria-hidden="true">→</span>
          </button>
        </div>
        <script is:inline define:vars={{ bgCandidates }}>
          (function () {
            // Only reveal the picker on localhost or when ?bg=pick is in the URL.
            // (Random rotation still happens for everyone in the inline script
            //  in <head>; this widget is just for choosing.)
            const isLocal = /^(localhost|127\.0\.0\.1|::1)$/.test(location.hostname) ||
                            location.hostname.endsWith(".local");
            const isOptIn = new URLSearchParams(location.search).get("bg") === "pick";
            if (!isLocal && !isOptIn) return;

            const wrapper = document.getElementById("bg-picker");
            if (wrapper) wrapper.hidden = false;

            const KEY = "pct_bg_choice";
            const nameEl = document.getElementById("bg-picker-name");
            const btn = document.getElementById("bg-picker-next");
            const cur = sessionStorage.getItem(KEY);
            if (nameEl) nameEl.textContent = cur || "—";
            if (btn) {
              btn.addEventListener("click", () => {
                const cur = sessionStorage.getItem(KEY);
                const others = bgCandidates.filter((b) => b !== cur);
                const next = (others.length > 0 ? others : bgCandidates)[
                  Math.floor(Math.random() * (others.length > 0 ? others.length : bgCandidates.length))
                ];
                sessionStorage.setItem(KEY, next);
                document.documentElement.style.setProperty(
                  "--bg-image",
                  `url("/bg/${next}")`
                );
                if (nameEl) nameEl.textContent = next;
                window.__pctBg = { all: bgCandidates, current: next };
              });
            }
          })();
        </script>
      )}

      <nav class="bottom-nav" aria-label="Main">
        <a href="/" class={`bottom-nav__item ${active === "home" ? "is-active" : ""}`}>
          <svg class="bottom-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12 12 3l9 9"/><path d="M5 10v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V10"/></svg>
          Home
        </a>
        <a href="/trail" class={`bottom-nav__item ${active === "trail" ? "is-active" : ""}`}>
          <svg class="bottom-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6 3 9v12l6-3 6 3 6-3V6l-6 3-6-3z"/><path d="M9 6v12"/><path d="M15 9v12"/></svg>
          Trail
        </a>
        <a href="/photos" class={`bottom-nav__item ${active === "photos" ? "is-active" : ""}`}>
          <svg class="bottom-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="6" width="18" height="14" rx="2"/><path d="M8 6 9.5 4h5L16 6"/><circle cx="12" cy="13" r="4"/></svg>
          Photos
        </a>
      </nav>
    </div>
  </body>
</html>
