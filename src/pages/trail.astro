---
import BaseLayout from "../layouts/BaseLayout.astro";
import routeGeoJson from "../data/route.json";
import photosData from "../data/photos.json";

const photos = (photosData as any[]).filter((p) => p.day != null);
---

<BaseLayout
  title="Trail map · Emily's PCT 2026"
  description="Interactive map of Emily's PCT route, daily camp/lodging stops, and every geotagged photo."
  active="trail"
  fullBleed={true}
>
  <header class="site-header" style="position: fixed; left: 0; right: 0; top: 0;">
    <div class="site-header__row">
      <h1 class="site-header__title"><a href="/">Emily's PCT 2026</a></h1>
      <span class="site-header__sub">Trail map</span>
    </div>
  </header>

  <div class="trail-page">
    <div class="trail-page__map" id="trailmap"></div>
  </div>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>

  <script is:inline define:vars={{ routeGeoJson, photos }}>
    document.addEventListener("DOMContentLoaded", () => {
      // eslint-disable-next-line no-undef
      const L = window.L;
      const map = L.map("trailmap", {
        zoomControl: true,
        scrollWheelZoom: true,
      });

      // base tiles - OpenTopoMap (terrain) is great for hiking; fall back to OSM
      L.tileLayer("https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png", {
        maxZoom: 17,
        attribution: 'Map &copy; <a href="https://opentopomap.org">OpenTopoMap</a> | © <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      }).addTo(map);

      // route lines
      const routeLayer = L.geoJSON(routeGeoJson, {
        filter: (f) => f.geometry.type === "LineString",
        style: (f) => ({
          color: f.properties.color || "#666",
          weight: 4,
          opacity: 0.85,
        }),
      }).addTo(map);

      // day-stop markers (camp / lodging)
      const stopColors = { Camp: "#5b6e4d", Hostel: "#b85935", Airbnb: "#b85935" };
      const stopFeatures = (routeGeoJson.features || []).filter((f) => f.geometry.type === "Point");
      const stopGroup = L.layerGroup();
      stopFeatures.forEach((f) => {
        const [lon, lat] = f.geometry.coordinates;
        const p = f.properties;
        const fill = stopColors[p.stop_type] || "#666";
        const marker = L.circleMarker([lat, lon], {
          radius: 7,
          color: "#fff",
          weight: 2,
          fillColor: fill,
          fillOpacity: 1,
        });
        const slug = `day-${String(p.day || 0).padStart(2, "0")}`;
        marker.bindPopup(
          `<strong>Day ${p.day} · ${p.stop_type || "Stop"}</strong><br>` +
          `<a href="/posts/${slug}">Read the day →</a>`
        );
        stopGroup.addLayer(marker);
      });
      stopGroup.addTo(map);

      // photo cluster
      // eslint-disable-next-line no-undef
      const photoCluster = L.markerClusterGroup({
        showCoverageOnHover: false,
        maxClusterRadius: 50,
        spiderfyOnMaxZoom: true,
        iconCreateFunction: (cluster) => {
          const count = cluster.getChildCount();
          return L.divIcon({
            html: `<div style="
              background:#b85935;color:#fff;border:2px solid #fff;
              border-radius:50%;width:36px;height:36px;
              display:flex;align-items:center;justify-content:center;
              font:600 0.85rem -apple-system,system-ui,sans-serif;
              box-shadow:0 1px 4px rgba(0,0,0,.4);
            ">${count}</div>`,
            className: "",
            iconSize: [36, 36],
          });
        },
      });

      // Group photos by (rounded lat, rounded lon) so that "burst" photos
      // taken steps apart become a single marker with a thumbnail strip
      // popup, rather than spiderfying out into a circle of pins.
      // 4 decimals ≈ 11 m; tweak if photos at the same spot are still
      // ending up as separate markers.
      const photoGroups = new Map();
      photos.forEach((p) => {
        const key = `${p.lat.toFixed(4)},${p.lon.toFixed(4)}`;
        if (!photoGroups.has(key)) photoGroups.set(key, []);
        photoGroups.get(key).push(p);
      });

      const MAX_THUMBS_IN_POPUP = 12;

      photoGroups.forEach((group) => {
        const first = group[0];
        const m = L.marker([first.lat, first.lon]);

        if (group.length === 1) {
          const slug = `day-${String(first.day).padStart(2, "0")}`;
          m.bindPopup(
            `<a href="/posts/${slug}"><img src="/photos/${first.thumb}" width="320" height="320" style="width:320px;height:auto;display:block;border-radius:6px" alt=""></a>` +
            `<br><a href="/posts/${slug}">Day ${first.day}</a>`,
            { maxWidth: 360, minWidth: 320 }
          );
        } else {
          const visible = group.slice(0, MAX_THUMBS_IN_POPUP);
          const overflow = group.length - visible.length;
          const slug = `day-${String(first.day).padStart(2, "0")}`;

          const strip = visible.map((p) => {
            const pSlug = `day-${String(p.day).padStart(2, "0")}`;
            return `<a href="/posts/${pSlug}"><img src="/photos/${p.thumb}" width="120" height="120" style="width:120px;height:120px;object-fit:cover;display:block;border-radius:4px" alt=""></a>`;
          }).join("");

          const overflowNote = overflow > 0
            ? `<div style="margin-top:6px;font-size:0.85rem;"><a href="/posts/${slug}">+${overflow} more →</a></div>`
            : "";

          // Day labels — usually a single day, but multi-day groups are possible.
          const days = [...new Set(group.map((p) => p.day))];
          const dayLabel = days.length === 1
            ? `Day ${days[0]}`
            : `Days ${Math.min(...days)}–${Math.max(...days)}`;

          m.bindPopup(
            `<div style="display:flex;flex-wrap:wrap;gap:4px;max-width:496px">${strip}</div>` +
            overflowNote +
            `<div style="margin-top:6px;font-size:0.85rem;"><a href="/posts/${slug}">${dayLabel} · ${group.length} photos →</a></div>`,
            { maxWidth: 520, minWidth: 320 }
          );
        }

        photoCluster.addLayer(m);
      });
      photoCluster.addTo(map);

      // fit bounds to route (default view)
      try {
        map.fitBounds(routeLayer.getBounds(), { padding: [16, 16] });
      } catch (_) {
        map.setView([34.0, -116.7], 9);
      }

      // Deep-link: ?day=N zooms to that day's stop and opens its popup.
      const params = new URLSearchParams(window.location.search);
      const focusDay = parseInt(params.get("day") || "", 10);
      if (Number.isFinite(focusDay)) {
        const target = stopFeatures.find((f) => f.properties.day === focusDay);
        if (target) {
          const [lon, lat] = target.geometry.coordinates;
          map.setView([lat, lon], 12, { animate: true });
          stopGroup.eachLayer((layer) => {
            const ll = layer.getLatLng();
            if (Math.abs(ll.lat - lat) < 1e-6 && Math.abs(ll.lng - lon) < 1e-6) {
              layer.openPopup();
            }
          });
        }
      }
    });
  </script>
</BaseLayout>
